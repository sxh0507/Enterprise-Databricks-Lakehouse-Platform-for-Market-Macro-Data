    "START_DATE = dbutils.widgets.get(\"start_date\").strip()\n",
    "END_DATE   = dbutils.widgets.get(\"end_date\").strip()\n",
    "SLEEP_MS   = int(dbutils.widgets.get(\"sleep_ms\"))\n",
